{
  "name": "teo-aios",
  "version": "2.0.0",
  "description": "Orquestrador TEO — Tecnologia de Execução Orquestrada",
  "main": "dist/aios.js",
  "bin": {
    "teo": "./dist/src/terminal/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "cli": "tsx src/terminal/cli.ts",
    "start": "tsx src/aios.js",
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');['src/codex/nichos','src/memory/trainer/nichos'].forEach(src=>{const dst=src.replace('src/','dist/src/');fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src))if(f.endsWith('.json')||f.endsWith('.md'))fs.copyFileSync(path.join(src,f),path.join(dst,f))})\"",
    "build:start": "npm run build && node dist/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@langchain/core": "^1.1.45",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/ollama": "^1.2.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.2",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "type": "commonjs"
}
